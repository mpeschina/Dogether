{
  "name": "Dogether Python 3.12",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  },
  "forwardPorts": [
    8501
  ],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "pip install --user -r requirements.txt"
}
